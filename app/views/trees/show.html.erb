<% content_for :title, t("trees.title", name: @person.display_name) %>

<div class="tree-page">
  <header class="page-head">
    <h1><%= @person.display_name %></h1>
    <div class="actions">
      <%# Mode toggle — always show both; active one is solid, other is outline %>
      <%= link_to t("trees.ancestors"),
            person_tree_path(@person, mode: "ancestors", depth: @depth),
            class: "button #{"button--outline" if @mode != "ancestors"}",
            aria: { current: @mode == "ancestors" ? "true" : nil } %>
      <%= link_to t("trees.descendants"),
            person_tree_path(@person, mode: "descendants", depth: @depth),
            class: "button #{"button--outline" if @mode != "descendants"}",
            aria: { current: @mode == "descendants" ? "true" : nil } %>

      <%# Depth controls %>
      <div class="depth-controls">
        <%= @depth > 1 ?
              link_to("−", person_tree_path(@person, mode: @mode, depth: @depth - 1), class: "button button--outline button--icon") :
              tag.span("−", class: "button button--outline button--icon button--disabled", aria: { disabled: true }) %>
        <span class="depth-label" title="<%= t("trees.depth_label") %>"><%= @depth %></span>
        <%= @depth < 6 ?
              link_to("+", person_tree_path(@person, mode: @mode, depth: @depth + 1), class: "button button--outline button--icon") :
              tag.span("+", class: "button button--outline button--icon button--disabled", aria: { disabled: true }) %>
      </div>

      <%= link_to t("trees.clan_link"), clan_tree_path, class: "button button--outline" %>
      <%= link_to t("maps.tree_link"), tree_map_path, class: "button button--outline" %>
      <%= link_to t("people.profile"), person_path(@person), class: "linkish" %>
    </div>
  </header>

  <p class="tree-hint"><%= t("trees.hint") %></p>

  <%= render "trees/canvas", graph: @graph, mode: @mode, depth: @depth, focus_id: @person.id %>
</div>
