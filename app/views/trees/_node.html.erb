<%# locals: node (graph node hash), focus (bool), mode (string), depth (integer) %>
<div class="tree-node <%= "tree-node--focus" if focus %> <%= node[:living] ? "tree-node--living" : "tree-node--#{node[:sex]&.downcase}" %>"
     data-tree-target="node"
     data-tree-node-id="<%= node[:id] %>">
  <% if node[:living] %>
    <p class="node-name node-name--living"><%= node[:name] %></p>
  <% else %>
    <%= link_to person_tree_path(node[:id], mode: mode, depth: depth) do %>
      <% if node[:avatar_url].present? %>
        <%= image_tag node[:avatar_url], class: "node-avatar", alt: node[:name] %>
      <% else %>
        <span class="node-avatar node-avatar--initials" aria-hidden="true"><%= node[:name].to_s.split.map(&:first).first(2).join.upcase %></span>
      <% end %>
      <div class="node-text">
        <%# Two lines — given names over surname — so full names stay readable at the
            fixed card width; single-line display_name when either half is missing. %>
        <% if node[:given].present? && node[:surname].present? %>
          <p class="node-name"><%= node[:given] %></p>
          <p class="node-surname"><%= node[:surname] %></p>
        <% else %>
          <p class="node-name"><%= node[:name] %></p>
        <% end %>
        <% if node[:birth_year].present? %>
          <p class="node-dates">b.&thinsp;<%= node[:birth_year] %></p>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
