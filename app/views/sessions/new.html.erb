<% content_for :title, t("auth.sign_in_title") %>

<div class="auth-wrap">
  <div class="auth-card">
    <h1><%= t("auth.sign_in_title") %></h1>

    <%= form_with url: session_path, class: "auth-form" do |form| %>
      <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", placeholder: t("auth.email_placeholder"),
            value: params[:email_address] %>
      <%= form.password_field :password, required: true, autocomplete: "current-password",
            maxlength: 72, placeholder: t("auth.password_placeholder") %>
      <%= form.submit t("auth.sign_in_submit"), class: "button" %>
    <% end %>

    <p class="auth-alt">
      <%= t("registrations.no_account") %>
      <%= link_to t("registrations.submit"), new_registration_path %>
    </p>
    <p class="auth-alt">
      <%= link_to t("auth.forgot_link"), new_password_path %>
    </p>
  </div>
</div>
