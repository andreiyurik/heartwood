<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<%= form_with url: session_path do |form| %>
  <%= form.email_field :email_address, required: true, autofocus: true,
        autocomplete: "username", placeholder: t("auth.email_placeholder"),
        value: params[:email_address] %><br>
  <%= form.password_field :password, required: true, autocomplete: "current-password",
        placeholder: t("auth.password_placeholder"), maxlength: 72 %><br>
  <%= form.submit t("auth.sign_in_submit") %>
<% end %>
<br>

<%= link_to t("auth.forgot_link"), new_password_path %>
