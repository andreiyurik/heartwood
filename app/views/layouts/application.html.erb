<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Heartwood" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Heartwood">
    <meta name="mobile-web-app-capable" content="yes">

    <%# SPA-like page refreshes: morph the DOM in place and preserve scroll (see docs/architecture/rails8-features.md) %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%# Lexxy editor styles (shipped by the lexxy gem) %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%# Leaflet map styles (CDN, MIT) — only used on the place/map views %>
    <%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <a href="<%= root_path %>" class="brand">🌳 Heartwood</a>
      <div class="site-header__right">
        <nav class="locale-switcher" aria-label="Language">
          <% I18n.available_locales.each do |loc| %>
            <%= link_to t("locale.#{loc}"), set_locale_path(loc),
                  class: "locale-switcher__btn #{"locale-switcher__btn--active" if I18n.locale == loc}",
                  aria: { current: I18n.locale == loc ? "true" : nil } %>
          <% end %>
        </nav>
        <% if authenticated? %>
          <%= turbo_stream_from Current.tree, :hints %>
          <%= render "hints/badge", count: Current.tree.duplicate_hints.pending.count %>
          <%= button_to t("nav.sign_out"), session_path, method: :delete, class: "linkish" %>
        <% end %>
      </div>
    </header>

    <% if notice %><div class="flash" role="status"><%= notice %></div><% end %>
    <% if alert %><div class="flash flash--alert" role="alert"><%= alert %></div><% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
