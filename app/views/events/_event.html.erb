<%= tag.li id: dom_id(event), class: "event-row" do %>
  <%= turbo_frame_tag dom_id(event, :edit) do %>
    <span class="event-kind"><%= event.kind_label %></span>
    <span class="event-summary"><%= event.summary %></span>
    <% if event.place %>
      <span class="event-place">· <%= event.place.name %></span>
    <% end %>
    <% if event.citations.loaded? ? event.citations.any? : event.citations.exists? %>
      <span class="sourced-badge" title="<%= t("citations.sourced_title") %>"><%= t("citations.sourced_badge") %></span>
    <% end %>
    <span class="event-actions">
      <%= link_to t("events.edit"), edit_person_event_path(person, event), class: "linkish" %>
      <%= render "shared/delete_button", url: person_event_path(person, event),
            label: t("events.remove"), confirm: t("events.remove_confirm") %>
    </span>
  <% end %>
  <%= render "citations/add_link", event: event, person: person %>
<% end %>
