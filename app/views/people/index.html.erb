<% content_for :title, "People" %>

<div class="page-head">
  <h1>People</h1>
  <%= link_to "Add person", new_person_path, class: "button" %>
</div>

<% if @people.any? %>
  <ul class="people-list">
    <%= render @people %>
  </ul>
<% else %>
  <p class="empty">No people yet. <%= link_to "Add the first one", new_person_path %>.</p>
<% end %>
