<% content_for :title, @person.display_name %>

<article class="person">
  <header class="page-head">
    <h1><%= @person.display_name %></h1>
    <div class="actions">
      <%= link_to t("people.tree"), person_tree_path(@person), class: "button button--outline" %>
      <%= link_to t("people.edit_button"), edit_person_path(@person), class: "button" %>
      <%= link_to t("nav.all_people"), people_path, class: "linkish" %>
    </div>
  </header>

  <dl class="facts">
    <% if @person.nickname.present? %>
      <dt><%= t("people.nickname_label") %></dt><dd><%= @person.nickname %></dd>
    <% end %>
    <dt><%= t("people.sex_label") %></dt><dd><%= t("people.sex.#{@person.sex}") %></dd>
    <dt><%= t("people.status_label") %></dt>
    <dd><%= @person.living? ? t("people.status.living") : t("people.status.deceased") %></dd>
  </dl>

  <%= render "events", person: @person %>

  <%= render "family", person: @person %>

  <%= button_to t("people.remove"), @person, method: :delete, class: "danger",
        form: { data: { turbo_confirm: t("people.remove_confirm", name: @person.display_name) } } %>
</article>
