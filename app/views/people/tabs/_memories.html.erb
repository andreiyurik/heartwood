<% if person.avatar.attached? %>
  <div class="memories-gallery">
    <%= image_tag person.avatar, class: "avatar avatar--gallery", alt: person.display_name %>
  </div>
  <p class="muted tab-stub" style="margin-top:1rem"><%= t("people.tabs.memories_more_stub") %></p>
<% else %>
  <p class="muted tab-stub"><%= t("people.tabs.memories_stub") %></p>
<% end %>
