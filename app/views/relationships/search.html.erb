<%# Candidate list for the relationship combobox. Picking one breaks out to the
    outer "relationship" frame, which re-renders with the named result. %>
<%= turbo_frame_tag "relationship_candidates" do %>
  <% if @matches.any? %>
    <ul class="combobox-options" role="listbox">
      <% @matches.each do |candidate| %>
        <li role="option">
          <%= link_to person_relationship_path(@person, with: candidate.id),
                class: "combobox-option", role: "button",
                data: { turbo_frame: "relationship" } do %>
            <span class="combobox-option-name"><%= candidate.display_name %></span>
            <% if candidate.birth&.date_raw.present? %>
              <span class="combobox-option-meta">b.&thinsp;<%= candidate.birth.date_raw %></span>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% elsif params[:q].present? %>
    <p class="combobox-empty"><%= t("relationships.search_none") %></p>
  <% end %>
<% end %>
